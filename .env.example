# central | helper
NODE_ROLE=central
NODE_ID=central-demo
PORT=3000
DATABASE_PATH=./data/central.sqlite

# Required when NODE_ROLE=helper
CENTRAL_URL=http://localhost:3000
HELPER_SYNC_MIN_INTERVAL_MS=1000
HELPER_SYNC_INTERVAL_MS=7000
HELPER_SYNC_MAX_BACKOFF_MS=60000
HELPER_SYNC_BATCH_SIZE=200

# Optional Web Push support
VAPID_SUBJECT=mailto:admin@example.com
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Helper -> central HMAC signing. The same secret must be configured on helper and central.
DCR_HELPER_SHARED_SECRET=local-dev-helper-secret
DCR_TRUSTED_HELPER_IDS=helper-demo
DCR_HELPER_SIGNATURE_TOLERANCE_SECONDS=300
